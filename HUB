          <div class="biz-grid">
            <button class="biz" type="button" data-name="Vice Motors"><i class="fas fa-bolt"></i>Vice Motors</button>
            <button class="biz" type="button" data-name="Tequi-La-La"><i class="fas fa-wine-bottle"></i>Tequi-La-La</button>
            <button class="biz" type="button" data-name="Pulse Audio"><i class="fas fa-headphones"></i>Pulse Audio</button>
            <button class="biz" type="button" data-name="Diamond Casino"><i class="fas fa-gem"></i>Diamond Casino</button>
            <button class="biz" type="button" data-name="Western Customs"><i class="fas fa-motorcycle"></i>Western Customs</button>
            <button class="biz" type="button" data-name="Vice Beach Co."><i class="fas fa-sun"></i>Vice Beach Co.</button>
