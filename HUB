<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>VICE CITY HUB · GTA 6</title>
  <meta name="description" content="A fan-made directory, leaderboard, and live tracker for GTA 6 — crews, garages, money routes, and the map. Unofficial, not affiliated with Rockstar Games.">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Space+Mono:wght@400;700&family=Inter:opsz,wght@14..32,400..800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
  <style>
    /* ============ TOKENS ============ */
    :root{
      --ink: #0b0915;
      --violet: #1f1730;
      --flamingo: #ff3e7f;
      --mango: #ffb23e;
      --teal: #1fd8c9;
      --sand: #fbf3e4;
      --flamingo-soft: rgba(255,62,127,.18);
      --mango-soft: rgba(255,178,62,.18);
      --teal-soft: rgba(31,216,201,.15);
      --line: rgba(251,243,228,.10);
      --line-strong: rgba(251,243,228,.20);
      --radius: 18px;
      --radius-lg: 28px;
      --container: 1180px;
      --glow-pink: 0 0 30px rgba(255,62,127,.25);
      --glow-gold: 0 0 30px rgba(255,178,62,.20);
    }
    *{ margin:0; padding:0; box-sizing:border-box; }
    html{ scroll-behavior:smooth; }
    body{
      background: var(--ink);
      color: var(--sand);
      font-family: 'Inter', sans-serif;
      font-size: 16px;
      line-height: 1.55;
      -webkit-font-smoothing: antialiased;
      overflow-x: hidden;
    }
    a{ color:inherit; }
    ::selection{ background: var(--flamingo); color: var(--ink); }

    /* ====== ANIMATED BG + PARTICLES ====== */
    .bg-glow {
      position: fixed;
      inset: 0;
      z-index: 0;
      background:
        radial-gradient(ellipse at 20% 50%, rgba(255,62,127,.15) 0%, transparent 55%),
        radial-gradient(ellipse at 80% 20%, rgba(31,216,201,.10) 0%, transparent 50%),
        radial-gradient(ellipse at 50% 80%, rgba(255,178,62,.08) 0%, transparent 50%),
        var(--ink);
      animation: bgShift 14s ease-in-out infinite alternate;
      pointer-events: none;
    }
    @keyframes bgShift {
      0% { filter: hue-rotate(-8deg) saturate(1.1); }
      100% { filter: hue-rotate(12deg) saturate(1.3); }
    }

    #particles-canvas {
      position: fixed;
      inset: 0;
      z-index: 1;
      pointer-events: none;
    }

    .grain{
      position: fixed; inset: 0; z-index: 2; pointer-events: none;
      opacity: .04; mix-blend-mode: overlay;
      background-image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' width='120' height='120'><filter id='n'><feTurbulence type='fractalNoise' baseFrequency='0.8' numOctaves='2' stitchTiles='stitch'/></filter><rect width='100%25' height='100%25' filter='url(%23n)'/></svg>");
      background-size: 180px 180px;
      animation: grainShift 1.2s steps(4) infinite;
    }
    @keyframes grainShift{
      0%{ transform: translate(0,0); }
      25%{ transform: translate(-2%,2%); }
      50%{ transform: translate(2%,-1%); }
      75%{ transform: translate(-1%,-2%); }
      100%{ transform: translate(0,0); }
    }

    .wrap{
      max-width: var(--container);
      margin: 0 auto;
      padding: 0 1.75rem;
      position: relative;
      z-index: 3;
    }

    /* ====== GLASS + GLOW ====== */
    .glass {
      background: rgba(11, 9, 21, .55);
      backdrop-filter: blur(16px);
      -webkit-backdrop-filter: blur(16px);
      border: 1px solid var(--line-strong);
      box-shadow: 0 20px 50px -20px rgba(0,0,0,.8), inset 0 0 40px rgba(255,62,127,.02);
    }

    .glow-border {
      position: relative;
    }
    .glow-border::after {
      content: '';
      position: absolute;
      inset: -2px;
      border-radius: inherit;
      padding: 2px;
      background: linear-gradient(135deg, var(--flamingo), var(--mango), var(--teal));
      -webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
      -webkit-mask-composite: xor;
      mask-composite: exclude;
      pointer-events: none;
      opacity: 0;
      transition: opacity .5s ease;
    }
    .glow-border:hover::after { opacity: 1; }

    /* ====== BOOT / TUNE-IN ====== */
    .boot{
      position: fixed; inset: 0; z-index: 300;
      background: var(--ink);
      display: flex; align-items: center; justify-content: center;
      transition: opacity .6s ease, visibility .6s ease;
    }
    .boot.is-hidden{ opacity: 0; visibility: hidden; pointer-events: none; }
    .boot-inner{ text-align: center; }
    .boot-freq{
      font-family: 'Bebas Neue', sans-serif;
      font-size: clamp(3.6rem, 12vw, 7rem);
      background: linear-gradient(135deg, var(--mango), var(--flamingo));
      -webkit-background-clip: text; -webkit-text-fill-color: transparent;
      letter-spacing: .04em;
    }
    .boot-label{
      font-family: 'Space Mono', monospace;
      font-size: .76rem; letter-spacing: .25em;
      color: rgba(251,243,228,.5); margin-top: .6rem; text-transform: uppercase;
    }
    .boot-bar{ width: 220px; height: 3px; background: rgba(251,243,228,.08); margin: 1.5rem auto 0; border-radius: 2px; overflow: hidden; }
    .boot-bar span{ display:block; height:100%; width:0%; background: linear-gradient(90deg, var(--flamingo), var(--mango)); animation: bootFill 1.1s ease forwards; }
    @keyframes bootFill{ to{ width: 100%; } }

    /* ====== HEADER ====== */
    header.site{
      position: sticky; top: 0; z-index: 40;
      backdrop-filter: blur(18px);
      -webkit-backdrop-filter: blur(18px);
      background: rgba(11,9,21,.78);
      border-bottom: 1px solid var(--line);
    }
    .site-bar{
      display:flex; align-items:center; justify-content:space-between;
      padding: .9rem 0;
      gap: 1rem;
    }
    .mark{ display:flex; align-items:center; gap:.7rem; }
    .mark .sun{
      width: 32px; height: 32px; border-radius: 50%;
      background: linear-gradient(135deg, var(--mango), var(--flamingo));
      box-shadow: 0 0 24px var(--flamingo-soft);
      flex-shrink: 0;
      animation: pulseGlow 2.8s ease-in-out infinite;
    }
    @keyframes pulseGlow {
      0%, 100% { box-shadow: 0 0 20px var(--flamingo-soft); }
      50% { box-shadow: 0 0 50px var(--flamingo-soft), 0 0 80px rgba(255,62,127,.10); }
    }
    .mark span{
      font-family: 'Bebas Neue', sans-serif;
      font-size: 1.5rem;
      letter-spacing: .06em;
      background: linear-gradient(135deg, var(--sand), var(--mango));
      -webkit-background-clip: text; -webkit-text-fill-color: transparent;
    }
    .mark small{
      display:block;
      font-family: 'Space Mono', monospace;
      font-size: .58rem;
      letter-spacing: .15em;
      color: rgba(251,243,228,.4);
      margin-top: -2px;
      -webkit-text-fill-color: rgba(251,243,228,.4);
    }

    .dj-chip{
      font-family: 'Space Mono', monospace;
      font-size: .72rem;
      color: rgba(251,243,228,.7);
      border: 1px solid var(--line-strong);
      padding: .42rem 1rem;
      border-radius: 40px;
      display:flex; align-items:center; gap:.55rem;
      cursor: pointer;
      transition: all .3s cubic-bezier(.2,.8,.2,1);
      background: rgba(255,178,62,.04);
    }
    .dj-chip:hover{
      border-color: var(--mango);
      color: var(--mango);
      box-shadow: var(--glow-gold);
      transform: scale(1.03);
    }
    .dj-chip i{ color: var(--flamingo); transition: .3s; }
    .dj-chip:hover i{ transform: rotate(15deg) scale(1.1); }

    /* ====== TICKER ====== */
    .ticker{
      border-bottom: 1px solid var(--line);
      background: var(--violet);
      overflow: hidden;
      white-space: nowrap;
    }
    .ticker-track{
      display:inline-flex;
      gap: 3rem;
      padding: .5rem 0;
      font-family: 'Space Mono', monospace;
      font-size: .7rem;
      letter-spacing: .08em;
      color: rgba(251,243,228,.65);
      animation: tickerScroll 28s linear infinite;
      will-change: transform;
    }
    .ticker-track i{ color: var(--mango); margin-right: .6em; }
    @keyframes tickerScroll{
      from{ transform: translateX(0); }
      to{ transform: translateX(-50%); }
    }

    /* ====== NOW PLAYING ====== */
    .now-playing{
      max-height: 0; overflow: hidden; opacity: 0;
      transition: max-height .4s ease, opacity .35s ease, padding .4s ease;
      display: flex; align-items: center; gap: .8rem;
      font-family: 'Space Mono', monospace; font-size: .74rem; color: rgba(251,243,228,.7);
      border-top: 1px solid var(--line);
    }
    .now-playing.is-visible{ max-height: 44px; opacity: 1; padding: .45rem 0; }
    .now-playing .dot{
      width:7px; height:7px; border-radius:50%;
      background: var(--flamingo);
      box-shadow: 0 0 0 4px var(--flamingo-soft);
      flex-shrink:0;
      animation: blinkDot 1.2s ease-in-out infinite;
    }
    @keyframes blinkDot{
      0%, 100%{ opacity:1; }
      50%{ opacity:.2; }
    }
    .now-playing strong{ color: var(--mango); }
    .np-online{ margin-left: auto; display:flex; align-items:center; gap:.5rem; color: rgba(251,243,228,.45); }

    /* ====== HERO ====== */
    .hero{
      position: relative;
      padding: 5.5rem 0 4rem;
      overflow: hidden;
      isolation: isolate;
    }
    .hero::before{
      content:'';
      position:absolute; inset:0; z-index:-1;
      background:
        radial-gradient(560px 360px at 78% 8%, var(--flamingo) 0%, transparent 62%),
        radial-gradient(480px 320px at 92% -6%, var(--mango) 0%, transparent 60%),
        var(--ink);
      opacity: .45;
      transform: translateY(var(--parallax, 0px));
    }
    .horizon-grid{
      position:absolute; left:0; right:0; bottom:-10%; height:60%; z-index:-1;
      background-image:
        linear-gradient(var(--line-strong) 1px, transparent 1px),
        linear-gradient(90deg, var(--line-strong) 1px, transparent 1px);
      background-size: 64px 64px;
      -webkit-mask-image: linear-gradient(to top, black, transparent 85%);
      mask-image: linear-gradient(to top, black, transparent 85%);
      transform: perspective(280px) rotateX(55deg);
      opacity: .4;
    }
    .hero-grid{
      display:grid;
      grid-template-columns: 1.3fr .9fr;
      gap: 3rem;
      align-items: end;
    }
    .hero h1{
      font-family: 'Bebas Neue', sans-serif;
      font-size: clamp(3.6rem, 9vw, 7.6rem);
      line-height: .88;
      margin-top: .6rem;
      background: linear-gradient(135deg, var(--sand) 30%, var(--mango) 65%, var(--flamingo) 100%);
      -webkit-background-clip: text; background-clip: text; -webkit-text-fill-color: transparent;
      filter: drop-shadow(0 0 40px rgba(255,178,62,.10));
    }
    .hero h1 small{
      display:block;
      font-family: 'Space Mono', monospace;
      font-size: clamp(.9rem, 1.5vw, 1.15rem);
      letter-spacing: .08em;
      color: rgba(251,243,228,.5);
      -webkit-text-fill-color: rgba(251,243,228,.5);
      margin-top: .6rem;
    }
    .hero p.lede{
      margin-top: 1.2rem;
      max-width: 46ch;
      font-size: 1.08rem;
      color: rgba(251,243,228,.65);
    }
    .hero-cta{ display:flex; gap: .9rem; margin-top: 2rem; flex-wrap: wrap; }
    .btn{
      font-family: 'Inter', sans-serif;
      font-weight: 700;
      font-size: .92rem;
      padding: .85rem 1.8rem;
      border-radius: 60px;
      border: 1px solid transparent;
      cursor: pointer;
      transition: all .3s cubic-bezier(.2,.8,.2,1);
      display:inline-flex; align-items:center; gap:.6rem;
      text-decoration: none;
    }
    .btn-solid{
      background: linear-gradient(135deg, var(--flamingo), var(--mango));
      color: var(--ink);
      box-shadow: 0 10px 30px -8px rgba(255,62,127,.3);
    }
    .btn-solid:hover{
      transform: translateY(-4px) scale(1.02);
      box-shadow: 0 20px 50px -10px rgba(255,62,127,.4);
    }
    .btn-ghost{
      background: transparent;
      border-color: var(--line-strong);
      color: var(--sand);
    }
    .btn-ghost:hover{
      border-color: var(--mango);
      color: var(--mango);
      transform: translateY(-2px);
      box-shadow: var(--glow-gold);
    }

    .hero-stat-card{
      background: rgba(11,9,21,.6);
      backdrop-filter: blur(12px);
      border: 1px solid var(--line-strong);
      border-radius: var(--radius-lg);
      padding: 1.6rem 1.8rem;
      box-shadow: 0 20px 50px -20px rgba(0,0,0,.8);
    }
    .hero-stat-card .label{
      font-family: 'Space Mono', monospace;
      font-size: .7rem; letter-spacing: .12em;
      color: rgba(251,243,228,.45);
      text-transform: uppercase;
    }
    .hero-stat-grid{
      display:grid; grid-template-columns: 1fr 1fr;
      gap: 1.2rem; margin-top: 1rem;
    }
    .hero-stat-grid .num{
      font-family: 'Bebas Neue', sans-serif;
      font-size: 2.2rem;
      color: var(--sand);
      line-height:1;
    }
    .hero-stat-grid .num span{ color: var(--mango); }

    /* ====== TUNABLE SECTIONS ====== */
    .eyebrow{
      font-family: 'Space Mono', monospace;
      font-size: .72rem;
      letter-spacing: .18em;
      text-transform: uppercase;
      color: var(--mango);
      display: inline-flex;
      align-items: center;
      gap: .5em;
    }
    .eyebrow::before{
      content: '';
      width: 7px; height: 7px;
      border-radius: 50%;
      background: var(--mango);
      box-shadow: 0 0 0 5px var(--mango-soft);
    }
    .section-head{ max-width: 640px; margin-bottom: 2.6rem; }
    .section-head h2{
      font-family: 'Bebas Neue', sans-serif;
      font-size: clamp(2.2rem, 4vw, 3.2rem);
      line-height: .96;
      margin: .4rem 0 .6rem;
      color: var(--sand);
    }
    .section-head p{ color: rgba(251,243,228,.55); font-size: 1.02rem; }
    section{ padding: 4.5rem 0; position: relative; }

    /* ====== TUNER ====== */
    .tuner-panel{
      background: rgba(11,9,21,.5);
      backdrop-filter: blur(14px);
      border: 1px solid var(--line-strong);
      border-radius: var(--radius-lg);
      padding: 2.2rem 2rem 1.8rem;
      box-shadow: 0 20px 50px -20px rgba(0,0,0,.8);
    }
    .tuner-head{
      display:flex; justify-content:space-between; align-items:flex-end;
      flex-wrap:wrap; gap:1.2rem; margin-bottom:1.8rem;
    }
    .tuner-head h2{ font-size: clamp(1.8rem, 3vw, 2.4rem); margin: .3rem 0 0; font-family: 'Bebas Neue', sans-serif; }
    .tuner-readout{ font-family: 'Space Mono', monospace; text-align: right; }
    .tuner-readout-label{ display:block; font-size: .6rem; letter-spacing: .12em; color: rgba(251,243,228,.4); text-transform: uppercase; }
    .tuner-readout-val{
      font-family: 'Bebas Neue', sans-serif;
      font-size: 2.4rem;
      color: var(--mango);
      display:block; line-height:1;
      font-variant-numeric: tabular-nums;
      text-shadow: 0 0 40px var(--mango-soft);
    }
    .tuner-readout-name{ font-size: .78rem; color: rgba(251,243,228,.6); }

    .tuner{ position: relative; height: 56px; padding: 0 1.8rem; touch-action: none; }
    .tuner-bar{
      position:absolute; left:1.8rem; right:1.8rem; top:50%; height:4px; transform:translateY(-50%);
      background: repeating-linear-gradient(90deg, var(--line-strong) 0 1px, transparent 1px 10px);
      border-radius: 2px;
    }
    .tuner-mark{
      position:absolute; top:50%; transform: translate(-50%,-50%);
      width:16px; height:16px; border-radius:50%;
      background: var(--ink);
      border: 2px solid var(--teal);
      cursor:pointer; padding:0;
      transition: all .3s cubic-bezier(.2,.8,.2,1);
      z-index: 2;
      touch-action: none;
    }
    .tuner-mark span{
      position:absolute; top: 155%; left:50%; transform: translateX(-50%);
      font-family: 'Space Mono', monospace; font-size: .62rem;
      color: rgba(251,243,228,.4); white-space: nowrap;
      pointer-events: none;
      transition: color .3s;
    }
    .tuner-mark:hover, .tuner-mark:focus-visible{ border-color: var(--mango); transform: translate(-50%,-50%) scale(1.15); }
    .tuner-mark.is-active{
      background: var(--mango);
      border-color: var(--mango);
      box-shadow: 0 0 0 8px var(--mango-soft);
      transform: translate(-50%,-50%) scale(1.1);
    }
    .tuner-mark.is-active span{ color: var(--mango); }

    .tuner-needle{
      position:absolute; top:50%; width:26px; height:26px; border-radius:50%;
      transform: translate(-50%,-50%);
      background: linear-gradient(135deg, var(--flamingo), var(--mango));
      box-shadow: 0 0 0 8px var(--flamingo-soft), 0 12px 30px -10px rgba(0,0,0,.7);
      cursor: grab;
      touch-action: none;
      transition: left .3s cubic-bezier(.2,.8,.2,1);
      z-index: 3;
    }
    .tuner-needle:active, .tuner-needle.dragging{ cursor: grabbing; transition: none; }
    .tuner-hint{ margin-top: 1.6rem; font-size: .78rem; color: rgba(251,243,228,.35); text-align:center; }
    .tuner-hint i{ color: var(--mango); margin-right: .4em; }

    /* ====== STATION CARDS ====== */
    .station-grid{
      display:grid;
      grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
      gap: 1.4rem;
    }
    .station{
      background: rgba(11,9,21,.4);
      backdrop-filter: blur(8px);
      border: 1px solid var(--line);
      border-radius: var(--radius);
      padding: 1.8rem 1.6rem;
      cursor: pointer;
      transition: all .4s cubic-bezier(.2,.8,.2,1);
      text-align: left;
      color: inherit;
      font: inherit;
      display:flex; flex-direction:column; gap: .9rem;
      position: relative;
      overflow: hidden;
    }
    .station::before{
      content:'';
      position:absolute; inset:0; border-radius:inherit;
      background: linear-gradient(135deg, var(--flamingo-soft), transparent 60%);
      opacity:0; transition:.4s;
      pointer-events:none;
    }
    .station:hover, .station:focus-visible{
      border-color: var(--flamingo);
      transform: translateY(-8px);
      box-shadow: var(--glow-pink);
    }
    .station:hover::before{ opacity:1; }
    .station .freq{
      font-family: 'Space Mono', monospace;
      font-size: 1.5rem;
      color: var(--mango);
      display:flex; align-items: baseline; gap: .4rem;
    }
    .station .freq small{ font-size: .6rem; color: rgba(251,243,228,.4); letter-spacing: .1em; }
    .station h3{ font-family: 'Bebas Neue', sans-serif; font-size: 1.6rem; letter-spacing: .02em; position:relative; }
    .station p{ color: rgba(251,243,228,.6); font-size: .92rem; flex-grow:1; position:relative; }
    .station .meta{
      display:flex; justify-content:space-between; align-items:center;
      font-family: 'Space Mono', monospace; font-size: .66rem;
      color: rgba(251,243,228,.4);
      border-top: 1px dashed var(--line); padding-top: .9rem;
      position:relative;
    }
    .station .meta i{ color: var(--teal); margin-right: .4em; }
    .station.is-on-air{ border-color: var(--mango); box-shadow: var(--glow-gold); }
    .station.is-on-air .freq{ color: var(--flamingo); }

    /* ====== CHARTS ====== */
    .chart-grid{
      display:grid;
      grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
      gap: 1.4rem;
    }
    .chart-panel{
      background: rgba(11,9,21,.4);
      backdrop-filter: blur(8px);
      border: 1px solid var(--line);
      border-radius: var(--radius);
      padding: 1.8rem;
      transition: all .3s cubic-bezier(.2,.8,.2,1);
    }
    .chart-panel:hover{
      border-color: var(--line-strong);
      transform: translateY(-4px);
      box-shadow: 0 15px 40px -15px rgba(0,0,0,.6);
    }
    .chart-panel h4{
      font-family: 'Inter', sans-serif; font-weight: 800; font-size: 1.02rem;
      display:flex; align-items:center; gap:.6rem; margin-bottom:1.3rem;
    }
    .chart-panel h4 i{ color: var(--flamingo); }
    .chart-row{ margin-bottom: 1.1rem; }
    .chart-row:last-child{ margin-bottom: 0; }
    .chart-row .top{
      display:flex; justify-content:space-between; align-items:baseline;
      font-size: .88rem; margin-bottom: .4rem;
    }
    .chart-row .rank{ font-family: 'Space Mono', monospace; color: var(--mango); margin-right: .5em; }
    .chart-row .val{ font-family: 'Space Mono', monospace; font-size: .78rem; color: rgba(251,243,228,.5); }
    .meter{ height: 6px; background: rgba(251,243,228,.06); border-radius: 4px; overflow:hidden; }
    .meter span{
      display:block; height:100%; border-radius: 4px;
      background: linear-gradient(90deg, var(--teal), var(--flamingo));
      width: 0%;
      transition: width 1.1s cubic-bezier(.2,.8,.2,1);
    }

    /* ====== PASSES ====== */
    .pass-grid{
      display:grid;
      grid-template-columns: repeat(auto-fit, minmax(270px, 1fr));
      gap: 1.6rem;
    }
    .pass{
      background: rgba(11,9,21,.4);
      backdrop-filter: blur(8px);
      border: 1px solid var(--line);
      border-radius: var(--radius);
      overflow: hidden;
      display:flex; flex-direction:column;
      transition: all .4s cubic-bezier(.2,.8,.2,1);
      position: relative;
    }
    .pass:hover{
      transform: translateY(-8px);
      border-color: var(--line-strong);
      box-shadow: 0 20px 50px -20px rgba(0,0,0,.8);
    }
    .pass .stripe{ height: 6px; background: var(--teal); flex-shrink:0; }
    .pass[data-tier="premium"] .stripe{ background: var(--mango); }
    .pass[data-tier="vip"] .stripe{ background: linear-gradient(90deg, var(--flamingo), var(--mango)); }
    .pass[data-tier="vip"]{ border-color: var(--flamingo); box-shadow: var(--glow-pink); }
    .pass-badge{
      position:absolute; top: 1rem; right: -2.8rem;
      background: linear-gradient(135deg, var(--flamingo), var(--mango));
      color: var(--ink);
      font-family: 'Space Mono', monospace; font-size: .6rem; font-weight:700; letter-spacing: .08em;
      padding: .25rem 3.2rem; transform: rotate(40deg);
      text-transform: uppercase;
    }
    .pass-body{ padding: 1.8rem 1.7rem 1.6rem; flex-grow:1; display:flex; flex-direction:column; }
    .pass-name{ font-family: 'Space Mono', monospace; font-size: .78rem; letter-spacing: .1em; text-transform: uppercase; color: rgba(251,243,228,.5); }
    .pass-price{ font-family: 'Bebas Neue', sans-serif; font-size: 3rem; margin: .2rem 0 1.2rem; line-height:1; }
    .pass-price small{ font-family: 'Inter', sans-serif; font-size: .95rem; font-weight:500; color: rgba(251,243,228,.45); }
    .pass ul{ list-style:none; margin-bottom: 1.6rem; flex-grow:1; }
    .pass li{
      display:flex; gap:.65rem; padding: .45rem 0;
      border-bottom: 1px solid var(--line);
      font-size: .88rem; color: rgba(251,243,228,.75);
    }
    .pass li i{ color: var(--teal); margin-top: .15rem; width:18px; }
    .pass li.off{ color: rgba(251,243,228,.3); }
    .pass li.off i{ color: rgba(251,243,228,.2); }
    .pass-btn{
      width:100%; padding:.85rem; border-radius:60px;
      border: 1px solid var(--line-strong);
      background: transparent;
      color: var(--sand);
      font-family: 'Inter', sans-serif; font-weight:700; font-size:.9rem;
      cursor:pointer;
      transition: all .3s cubic-bezier(.2,.8,.2,1);
    }
    .pass-btn:hover{ border-color: var(--mango); color: var(--mango); box-shadow: var(--glow-gold); }
    .pass[data-tier="vip"] .pass-btn{
      background: linear-gradient(135deg, var(--flamingo), var(--mango));
      color: var(--ink); border-color: transparent;
      box-shadow: 0 10px 30px -8px rgba(255,62,127,.2);
    }
    .pass[data-tier="vip"] .pass-btn:hover{ filter: brightness(1.08); transform: scale(1.02); }
    .pass-btn.is-current{ border-color: var(--teal); color: var(--teal); cursor: default; }

    /* ====== MAP + BIZ ====== */
    .split{ display:grid; grid-template-columns: 1.25fr .9fr; gap: 1.6rem; align-items: stretch; }
    .panel{
      background: rgba(11,9,21,.4);
      backdrop-filter: blur(12px);
      border: 1px solid var(--line);
      border-radius: var(--radius-lg);
      padding: 2rem;
      transition: all .4s cubic-bezier(.2,.8,.2,1);
    }
    .panel:hover{
      border-color: var(--line-strong);
      box-shadow: 0 20px 50px -20px rgba(0,0,0,.8);
    }
    .panel h3{
      font-family: 'Bebas Neue', sans-serif;
      font-size: 2rem;
      display:flex; align-items:center; gap: .7rem;
      margin-bottom: 1.4rem;
    }
    .panel h3 .live{
      font-family: 'Space Mono', monospace; font-size: .6rem; letter-spacing: .1em;
      background: var(--flamingo-soft); color: var(--flamingo);
      border: 1px solid rgba(255,62,127,.25);
      padding: .2rem .8rem; border-radius: 40px;
    }
    .radar-wrap{ display:flex; align-items:center; gap: 1.6rem; flex-wrap: wrap; }
    .radar-svg{ width: 168px; height: 168px; flex-shrink: 0; }
    .radar-ring{ fill: none; stroke: var(--teal-soft); stroke-width: 1; }
    .radar-cross{ stroke: var(--teal-soft); stroke-width: 1; }
    .radar-sweep{ transform-origin: 120px 120px; animation: radarSpin 4.5s linear infinite; }
    .radar-sweep path{ fill: url(#sweepGrad); }
    @keyframes radarSpin{ to{ transform: rotate(360deg); } }
    .radar-blip{ fill: var(--mango); animation: blip 2.2s ease-in-out infinite; transform-box: fill-box; transform-origin: center; }
    @keyframes blip{ 0%,100%{ opacity:.3; transform: scale(.8); } 50%{ opacity:1; transform: scale(1.4); } }

    .radar-readout{ flex:1; min-width: 160px; }
    .radar-readout .online{ font-family: 'Bebas Neue', sans-serif; font-size: 2.4rem; color: var(--sand); }
    .radar-readout .online-label{ font-family: 'Space Mono', monospace; font-size: .66rem; color: rgba(251,243,228,.4); letter-spacing: .08em; margin-bottom: .2rem; }

    .stat-strip{
      display:flex; gap: 1.8rem; flex-wrap: wrap;
      margin-top: 1.8rem; padding-top: 1.5rem;
      border-top: 1px dashed var(--line);
    }
    .stat-strip div{ font-size: .8rem; color: rgba(251,243,228,.55); }
    .stat-strip b{ display:block; font-family: 'Bebas Neue', sans-serif; font-size: 1.5rem; color: var(--sand); font-weight:400; }

    .biz-grid{ display:flex; flex-wrap:wrap; gap: .7rem; margin-top: .3rem; }
    .biz{
      background: rgba(11,9,21,.5);
      border: 1px solid var(--line);
      padding: .6rem 1.2rem;
      border-radius: 60px;
      font-size: .82rem; font-weight:600;
      display:flex; align-items:center; gap: .5rem;
      cursor:pointer;
      transition: all .3s cubic-bezier(.2,.8,.2,1);
    }
    .biz i{ color: var(--mango); transition: .3s; }
    .biz:hover{
      border-color: var(--flamingo);
      background: var(--flamingo-soft);
      transform: translateY(-4px);
      box-shadow: var(--glow-pink);
    }
    .biz:hover i{ transform: rotate(15deg) scale(1.15); color: var(--flamingo); }
    .panel .note{ margin-top: 1.4rem; font-size: .78rem; color: rgba(251,243,228,.35); }

    /* ====== FOOTER ====== */
    footer.site{
      border-top: 1px solid var(--line);
      padding: 3.2rem 0 2.4rem;
      margin-top: 1rem;
    }
    .foot-top{ display:flex; justify-content:space-between; align-items:center; flex-wrap:wrap; gap:1.4rem; margin-bottom:1.8rem; }
    .foot-links{ display:flex; gap: 1.3rem; }
    .foot-links a{
      color: rgba(251,243,228,.4);
      font-size: 1.3rem;
      transition: all .3s cubic-bezier(.2,.8,.2,1);
      display:inline-block;
    }
    .foot-links a:hover{
      color: var(--mango);
      transform: translateY(-4px) scale(1.1);
      text-shadow: var(--glow-gold);
    }
    .foot-legal{
      font-size: .76rem;
      color: rgba(251,243,228,.3);
      max-width: 60ch;
      line-height: 1.7;
    }
    .foot-legal strong{ color: rgba(251,243,228,.5); }

    /* ====== TOASTS ====== */
    .toast-root{
      position: fixed; bottom: 1.4rem; right: 1.4rem; z-index: 100;
      display:flex; flex-direction:column; gap: .6rem;
      max-width: min(340px, calc(100vw - 2.8rem));
    }
    .toast{
      background: var(--violet);
      border: 1px solid var(--line-strong);
      border-left: 4px solid var(--mango);
      padding: .85rem 1.1rem;
      border-radius: 14px;
      font-size: .85rem;
      box-shadow: 0 20px 50px -16px rgba(0,0,0,.8);
      animation: toastIn .4s cubic-bezier(.2,.8,.2,1);
      display:flex; align-items:flex-start; gap:.6rem;
      backdrop-filter: blur(10px);
    }
    .toast i{ color: var(--mango); margin-top: .15rem; }
    .toast.leaving{ animation: toastOut .25s ease forwards; }
    @keyframes toastIn{ from{ opacity:0; transform: translateY(14px); } to{ opacity:1; transform:none; } }
    @keyframes toastOut{ to{ opacity:0; transform: translateX(16px); } }

    /* ====== RESPONSIVE ====== */
    @media (max-width: 880px){
      .hero-grid{ grid-template-columns:1fr; }
      .split{ grid-template-columns:1fr; }
      section{ padding:3.6rem 0; }
    }
    @media (max-width: 560px){
      .wrap{ padding:0 1.2rem; }
      .pass-badge{ display:none; }
      .hero{ padding-top:3.2rem; }
      .hero-stat-grid{ grid-template-columns:1fr 1fr; gap:.8rem; }
    }

    /* ====== REVEAL ====== */
    .reveal{
      opacity:0; transform:translateY(30px);
      transition: opacity .7s cubic-bezier(.2,.8,.2,1), transform .7s cubic-bezier(.2,.8,.2,1);
    }
    .reveal.is-visible{ opacity:1; transform:none; }

    .btn, .station, .pass, .biz, .dj-chip, .tuner-mark, .pass-btn{
      -webkit-tap-highlight-color: transparent;
    }
  </style>
</head>
