  <!-- TOAST ROOT -->
  <div class="toast-root" id="toastRoot" aria-live="polite"></div>

<script>
(function(){
  "use strict";

  var reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  var pointerFine = window.matchMedia('(pointer: fine)').matches;

  /* ===== PARTICLES ===== */
  (function particles(){
    var canvas = document.getElementById('particles-canvas');
    if (!canvas) return;
    var ctx = canvas.getContext('2d');
    var w, h;
    var particles = [];
    var COUNT = 100;

    function resize(){
      w = canvas.width = window.innerWidth;
      h = canvas.height = window.innerHeight;
    }
    window.addEventListener('resize', resize);
    resize();

    function Particle(){
      this.x = Math.random() * w;
      this.y = Math.random() * h;
      this.size = Math.random() * 2.8 + 0.5;
      this.speedX = (Math.random() - 0.5) * 0.3;
      this.speedY = (Math.random() - 0.5) * 0.3;
      this.opacity = Math.random() * 0.3 + 0.1;
    }
    Particle.prototype.update = function(){
      this.x += this.speedX;
      this.y += this.speedY;
      if (this.x < 0 || this.x > w) this.speedX *= -1;
      if (this.y < 0 || this.y > h) this.speedY *= -1;
    };
    Particle.prototype.draw = function(){
      ctx.beginPath();
      ctx.arc(this.x, this.y, this.size, 0, Math.PI * 2);
      ctx.fillStyle = 'rgba(255, 180, 220, ' + this.opacity + ')';
      ctx.fill();
    };

    for (var i = 0; i < COUNT; i++) particles.push(new Particle());

    function animate(){
      ctx.clearRect(0, 0, w, h);
      for (var i = 0; i < particles.length; i++) {
        particles[i].update();
        particles[i].draw();
      }
      // connection lines
      for (var i = 0; i < particles.length; i++) {
        for (var j = i + 1; j < particles.length; j++) {
          var dx = particles[i].x - particles[j].x;
          var dy = particles[i].y - particles[j].y;
          var dist = Math.sqrt(dx*dx + dy*dy);
          if (dist < 120) {
            ctx.beginPath();
            ctx.moveTo(particles[i].x, particles[i].y);
            ctx.lineTo(particles[j].x, particles[j].y);
            ctx.strokeStyle = 'rgba(255, 150, 200, ' + (0.05 * (1 - dist/120)) + ')';
            ctx.lineWidth = 0.5;
            ctx.stroke();
          }
        }
      }
      requestAnimationFrame(animate);
    }
    if (!reduceMotion) animate();
  })();

  /* ===== BOOT ===== */
  (function boot(){
    var overlay = document.getElementById('bootOverlay');
    if (!overlay) return;
    if (reduceMotion || sessionStorage.getItem('vch_booted') === '1'){ overlay.remove(); return; }
    var freqEl = document.getElementById('bootFreq');
    var ticks = 0;
    var scanTimer = setInterval(function(){
      freqEl.textContent = (87.5 + Math.random() * 20.5).toFixed(1);
      ticks++;
      if (ticks > 9){ clearInterval(scanTimer); freqEl.textContent = '88.3'; }
    }, 90);
    setTimeout(function(){
      overlay.classList.add('is-hidden');
      sessionStorage.setItem('vch_booted', '1');
      setTimeout(function(){ overlay.remove(); }, 550);
    }, 1300);
  })();

  /* ===== TOAST ===== */
  var toastRoot = document.getElementById('toastRoot');
  function toast(msg, icon){
    var el = document.createElement('div');
    el.className = 'toast';
    el.innerHTML = '<i class="fas ' + (icon || 'fa-circle-check') + '"></i><span>' + msg + '</span>';
    toastRoot.appendChild(el);
    setTimeout(function(){ el.classList.add('leaving'); setTimeout(function(){ el.remove(); }, 260); }, 3200);
  }

  /* ===== TICKER ===== */
  var tickerLines = [
    'WVC 96.9 · LIVE FROM VICE BEACH',
    'TRAFFIC: CAUSEWAY CLEAR, OCEAN DRIVE BACKED UP',
    'FAN BROADCAST — NOT AFFILIATED WITH ROCKSTAR GAMES',
    'CHART UPDATE LANDING NEXT WEEK',
    'TUNE TO 88.3 FOR LIVE MAP PINS'
  ];
  var track = document.getElementById('tickerTrack');
  var html = '';
  for (var r = 0; r < 2; r++){
    tickerLines.forEach(function(line){
      html += '<span><i class="fas fa-circle" style="font-size:.4rem;"></i>' + line + '</span>';
    });
  }
  track.innerHTML = html;

  /* ===== ONLINE COUNTER ===== */
  var online = 14206;
  var onlineEls = [document.getElementById('heroOnline'), document.getElementById('mapOnline'), document.getElementById('npOnline')];
  function paintOnline(){
    onlineEls.forEach(function(el){ if (el) el.textContent = online.toLocaleString(); });
  }
  if (!reduceMotion){
    setInterval(function(){
      online = Math.max(13000, online + Math.floor(Math.random() * 30) - 12);
      paintOnline();
    }, 5000);
  }

  /* ===== COUNT-UP + METERS ===== */
  function countUp(el, target, duration){
    duration = duration || 1100;
    var startTime = null;
    function step(ts){
      if (!startTime) startTime = ts;
      var p = Math.min((ts - startTime) / duration, 1);
      var eased = 1 - Math.pow(1 - p, 3);
      el.textContent = Math.round(target * eased).toLocaleString();
      if (p < 1) requestAnimationFrame(step);
      else el.textContent = target.toLocaleString();
    }
    requestAnimationFrame(step);
  }
  var counters = document.querySelectorAll('[data-count]');
  var meters = document.querySelectorAll('.meter span');
  if ('IntersectionObserver' in window){
    var ioCount = new IntersectionObserver(function(entries){
      entries.forEach(function(entry){
        if (!entry.isIntersecting) return;
        var el = entry.target;
        var target = parseInt(el.getAttribute('data-count'), 10);
        if (reduceMotion) el.textContent = target.toLocaleString();
        else countUp(el, target);
        ioCount.unobserve(el);
      });
    }, { threshold: .5 });
    counters.forEach(function(c){ ioCount.observe(c); });

    var ioMeter = new IntersectionObserver(function(entries){
      entries.forEach(function(entry){
        if (!entry.isIntersecting) return;
        var s = entry.target;
        s.style.width = s.getAttribute('data-w') + '%';
        ioMeter.unobserve(s);
      });
    }, { threshold: .4 });
    meters.forEach(function(m){ ioMeter.observe(m); });
  } else {
    counters.forEach(function(c){ c.textContent = c.getAttribute('data-count'); });
    meters.forEach(function(m){ m.style.width = m.getAttribute('data-w') + '%'; });
  }

  /* ===== SCROLL REVEAL ===== */
  var revealTargets = document.querySelectorAll('.section-head, .station, .chart-panel, .pass, .panel');
  revealTargets.forEach(function(el, i){
    el.classList.add('reveal');
    el.style.transitionDelay = (Math.min(i % 4, 3) * 70) + 'ms';
  });
  var allReveal = document.querySelectorAll('.reveal');
  if ('IntersectionObserver' in window){
    var ioReveal = new IntersectionObserver(function(entries){
      entries.forEach(function(entry){
        if (entry.isIntersecting){ entry.target.classList.add('is-visible'); ioReveal.unobserve(entry.target); }
      });
    }, { threshold: .12 });
    allReveal.forEach(function(el){ ioReveal.observe(el); });
  } else {
    allReveal.forEach(function(el){ el.classList.add('is-visible'); });
  }

  /* ===== TILT (fine pointer only) ===== */
  if (!reduceMotion && pointerFine){
    document.querySelectorAll('.station, .pass, .chart-panel, .panel').forEach(function(card){
      card.addEventListener('mousemove', function(e){
        var rect = card.getBoundingClientRect();
        var x = (e.clientX - rect.left) / rect.width - .5;
        var y = (e.clientY - rect.top) / rect.height - .5;
        card.style.transform = 'perspective(700px) rotateX(' + (y * -4) + 'deg) rotateY(' + (x * 4) + 'deg) translateY(-4px)';
      });
      card.addEventListener('mouseleave', function(){ card.style.transform = ''; });
    });
  }

  /* ===== PARALLAX ===== */
  var heroEl = document.querySelector('.hero');
  if (heroEl && !reduceMotion){
    var ticking = false;
    window.addEventListener('scroll', function(){
      if (ticking) return;
      ticking = true;
      requestAnimationFrame(function(){
        var y = Math.min(window.scrollY, heroEl.offsetHeight);
        heroEl.style.setProperty('--parallax', (y * 0.18) + 'px');
        ticking = false;
      });
    }, { passive: true });
  }

  /* ===== NOW PLAYING ===== */
  var npBar = document.getElementById('nowPlaying');
  if (heroEl && npBar && 'IntersectionObserver' in window){
    var ioHero = new IntersectionObserver(function(entries){
      entries.forEach(function(entry){
        npBar.classList.toggle('is-visible', !entry.isIntersecting);
      });
    }, { threshold: 0, rootMargin: '-64px 0px 0px 0px' });
    ioHero.observe(heroEl);
  }

  /* ===== TUNER ===== */
  var stations = [
    { freq: '88.3', name: 'Map Control', pct: 3.9 },
    { freq: '91.1', name: 'Crew Directory', pct: 17.6 },
    { freq: '96.5', name: 'Money Routes', pct: 43.9 },
    { freq: '104.7', name: 'Garage & Specs', pct: 83.9 }
  ];
  var needle = document.getElementById('tunerNeedle');
  var tunerTrack = document.getElementById('tunerTrack');
  var currentFreq = '88.3';

  function setStation(freq, name, announce){
    currentFreq = freq;
    var freqVal = document.getElementById('tunerFreqVal');
    var nameVal = document.getElementById('tunerStationName');
    if (freqVal) freqVal.textContent = freq;
    if (nameVal) nameVal.textContent = name;
    var npFreq = document.getElementById('npFreq');
    var npName = document.getElementById('npName');
    if (npFreq) npFreq.textContent = freq;
    if (npName) npName.textContent = name;
    if (needle) needle.setAttribute('aria-valuenow', freq);
    document.querySelectorAll('.tuner-mark').forEach(function(m){
      m.classList.toggle('is-active', m.getAttribute('data-freq') === freq);
    });
    document.querySelectorAll('.station').forEach(function(card){
      card.classList.toggle('is-on-air', card.getAttribute('data-freq') === freq);
    });
    if (announce) toast('On air: ' + freq + ' FM — ' + name, 'fa-tower-broadcast');
  }

  function nearestStation(pct){
    var best = stations[0], min = Infinity;
    stations.forEach(function(s){
      var d = Math.abs(s.pct - pct);
      if (d < min){ min = d; best = s; }
    });
    return best;
  }

  function pctFromClientX(clientX){
    var rect = tunerTrack.getBoundingClientRect();
    var pad = 1.8 * parseFloat(getComputedStyle(document.documentElement).fontSize);
    var usableLeft = rect.left + pad;
    var usableWidth = rect.width - pad * 2;
    return Math.max(0, Math.min(100, ((clientX - usableLeft) / usableWidth) * 100));
  }

  if (needle && tunerTrack){
    var dragging = false;
    needle.addEventListener('pointerdown', function(e){ dragging = true; needle.classList.add('dragging'); needle.setPointerCapture(e.pointerId); });
    needle.addEventListener('pointermove', function(e){
      if (!dragging) return;
      var pct = pctFromClientX(e.clientX);
      needle.style.left = pct + '%';
      var nearest = nearestStation(pct);
      document.querySelectorAll('.tuner-mark').forEach(function(m){
        m.classList.toggle('is-active', m.getAttribute('data-freq') === nearest.freq);
      });
    });
    function releaseDrag(e){
      if (!dragging) return;
      dragging = false;
      needle.classList.remove('dragging');
      var pct = pctFromClientX(e.clientX);
      var nearest = nearestStation(pct);
      needle.style.left = nearest.pct + '%';
      setStation(nearest.freq, nearest.name, true);
    }
    needle.addEventListener('pointerup', releaseDrag);
    needle.addEventListener('pointercancel', releaseDrag);
    needle.addEventListener('keydown', function(e){
      var idx = stations.findIndex(function(s){ return s.freq === currentFreq; });
      if (e.key === 'ArrowRight') idx = Math.min(stations.length - 1, idx + 1);
      else if (e.key === 'ArrowLeft') idx = Math.max(0, idx - 1);
      else return;
      e.preventDefault();
      var s = stations[idx];
      needle.style.left = s.pct + '%';
      setStation(s.freq, s.name, true);
    });
    document.querySelectorAll('.tuner-mark').forEach(function(m){
      m.addEventListener('click', function(){
        var freq = m.getAttribute('data-freq');
        var name = m.getAttribute('data-name');
        needle.style.left = m.style.left;
        setStation(freq, name, true);
      });
    });
  }

  /* ===== STATION CLICKS ===== */
  document.querySelectorAll('.station').forEach(function(btn){
    btn.addEventListener('click', function(){
      var name = btn.getAttribute('data-name');
      var freq = btn.getAttribute('data-freq');
      var marker = document.querySelector('.tuner-mark[data-freq="' + freq + '"]');
      if (needle && marker) needle.style.left = marker.style.left;
      setStation(freq, name, true);
    });
  });

  /* ===== BIZ CLICKS ===== */
  document.querySelectorAll('.biz').forEach(function(btn){
    btn.addEventListener('click', function(){
      toast(btn.getAttribute('data-name') + ' — added to the notify list', 'fa-bell');
    });
  });

  /* ===== MAP PING ===== */
  var pingBtn = document.getElementById('pingMap');
  if (pingBtn){
    pingBtn.addEventListener('click', function(){
      var ev = document.getElementById('eventCount');
      var col = document.getElementById('collectibleCount');
      ev.textContent = parseInt(ev.textContent, 10) + 1;
      col.textContent = parseInt(col.textContent, 10) + Math.floor(Math.random() * 2);
      toast('Nearest pin: 2.3 km, Vice Beach safehouse', 'fa-location-crosshairs');
    });
  }

  /* ===== PASS BUTTONS ===== */
  document.querySelectorAll('.pass-btn:not([disabled])').forEach(function(btn){
    btn.addEventListener('click', function(){
      var tier = btn.getAttribute('data-tier');
      var label = tier === 'vip' ? 'VIP All-Access' : 'Member';
      toast('Selected ' + label + ' — payments aren\'t wired up yet, this is a demo.', 'fa-id-badge');
    });
  });

  /* ===== CREDIT CHIP ===== */
  var chip = document.getElementById('creditChip');
  if (chip){
    chip.addEventListener('click', function(){
      toast('Built by The Real Pae / Heat Barz Agent 007', 'fa-headset');
    });
  }

})();
</script>
